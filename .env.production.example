APP_NAME=ISTURA
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://example.go.id
APP_TIMEZONE=Asia/Jakarta

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=istura
DB_USERNAME=istura
DB_PASSWORD=
DB_SOCKET=

SESSION_DRIVER=database
SESSION_LIFETIME=60
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SAME_SITE=lax

SANCTUM_STATEFUL_DOMAINS=example.go.id
TRUSTED_PROXIES=
CORS_ALLOWED_ORIGINS=https://example.go.id
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# Hari retensi riwayat aktivitas (audit log). Entri lebih tua dipangkas
# otomatis oleh command audit:prune (perlu scheduler cron aktif). 0 = nonaktif.
AUDIT_LOG_RETENTION_DAYS=180

# Provider tanggal merah Indonesia untuk auto-sync jadwal.
INDONESIAN_HOLIDAYS_URL=https://raw.githubusercontent.com/guangrei/APIHariLibur_V2/main/holidays.json
INDONESIAN_HOLIDAYS_TIMEOUT=10
INDONESIAN_HOLIDAYS_AUTO_SYNC=true
INDONESIAN_HOLIDAYS_AUTO_SYNC_RETRY_MINUTES=5

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_FROM_ADDRESS="no-reply@example.go.id"
MAIL_FROM_NAME="${APP_NAME}"

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=example.go.id
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_ALLOWED_ORIGINS=https://example.go.id
REVERB_APP_RATE_LIMITING_ENABLED=true

VITE_APP_NAME="${APP_NAME}"
VITE_PUBLIC_APP_URL="${APP_URL}"
VITE_REVERB_ENABLED=true
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Isi hanya saat bootstrap admin pertama, lalu rotate password dan kosongkan.
SEED_ADMIN_PASSWORD=

PUBLIC_BOOKING_ACTIVE_IDENTITY_LIMIT=5
PUBLIC_BOOKING_PENDING_TTL_HOURS=48
