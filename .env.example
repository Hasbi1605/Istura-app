APP_NAME=ISTURA
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Jakarta

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# --- Database (MySQL) ---
# Catatan: instalasi Homebrew di mesin dev ini berjalan di port 3307.
# Sesuaikan DB_PORT bila MySQL Anda di 3306 (default).
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=istura
DB_USERNAME=root
DB_PASSWORD=
DB_SOCKET=

SESSION_DRIVER=database
SESSION_LIFETIME=120
ADMIN_SESSION_ABSOLUTE_LIFETIME=720
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false
SESSION_PATH=/
SESSION_DOMAIN=localhost
SESSION_SAME_SITE=lax

SANCTUM_STATEFUL_DOMAINS=localhost:8000,localhost,127.0.0.1:8000,127.0.0.1
SANCTUM_EXPIRATION=1440

# Comma-separated extra hosts allowed for CMS-managed public image URLs.
# Relative /assets and /storage paths are always allowed.
PUBLIC_IMAGE_HOSTS=

# Hari retensi riwayat aktivitas (audit log). Entri lebih tua dipangkas
# otomatis oleh command audit:prune (dijadwalkan harian). 0 = nonaktif.
AUDIT_LOG_RETENTION_DAYS=180

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@istura.id"
MAIL_FROM_NAME="${APP_NAME}"

# --- Reverb (WebSocket realtime) ---
REVERB_APP_ID=istura-app
REVERB_APP_KEY=istura-key
REVERB_APP_SECRET=istura-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:5175
REVERB_APP_RATE_LIMITING_ENABLED=true

VITE_APP_NAME="${APP_NAME}"
VITE_PUBLIC_APP_URL="${APP_URL}"
VITE_REVERB_ENABLED=true
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Local/dev only. Jangan pakai password umum di production.
SEED_ADMIN_PASSWORD=
